---
---

<section class="bg-gray-light py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <p class="animate-on-scroll text-orange font-bold text-sm tracking-widest mb-4" data-animation="fade-in">COMPARISON</p>
      <h2 class="animate-on-scroll text-2xl sm:text-3xl md:text-4xl font-black text-navy leading-tight" data-animation="fade-up">
        圧倒的なコストパフォーマンス
      </h2>
    </div>

    <div class="max-w-3xl mx-auto space-y-6" id="comparison-bars">
      <!-- Bar 1 -->
      <div class="animate-on-scroll" data-animation="fade-in" data-delay="0.1s">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-bold text-navy">一般的な顧問契約（年間）</span>
          <span class="font-accent font-bold text-navy text-lg">240〜480<span class="text-sm font-sans font-normal">万円</span></span>
        </div>
        <div class="h-12 bg-white rounded-xl overflow-hidden">
          <div class="comparison-bar h-full bg-navy/20 rounded-xl flex items-center justify-end pr-4 transition-all duration-1000 ease-out" data-target-width="100%" style="width: 0%">
            <span class="text-xs text-navy/60 font-bold whitespace-nowrap opacity-0 transition-opacity duration-300 delay-700" data-bar-label>月額20〜40万円 × 12ヶ月</span>
          </div>
        </div>
      </div>

      <!-- Bar 2 -->
      <div class="animate-on-scroll" data-animation="fade-in" data-delay="0.3s">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-bold text-navy">通常の一日研修（5名×年3回）</span>
          <span class="font-accent font-bold text-navy text-lg">約30〜60<span class="text-sm font-sans font-normal">万円</span></span>
        </div>
        <div class="h-12 bg-white rounded-xl overflow-hidden">
          <div class="comparison-bar h-full bg-navy/15 rounded-xl transition-all duration-1000 ease-out" data-target-width="50%" style="width: 0%">
          </div>
        </div>
      </div>

      <!-- Bar 3 (highlight) -->
      <div class="animate-on-scroll" data-animation="fade-in" data-delay="0.5s">
        <div class="flex items-center justify-between mb-2">
          <span class="text-sm font-bold text-orange">本サービス（年間）</span>
          <span class="font-accent font-extrabold text-orange text-2xl">24<span class="text-sm font-sans font-bold">万円</span></span>
        </div>
        <div class="h-12 bg-white rounded-xl overflow-hidden">
          <div class="comparison-bar h-full bg-gradient-to-r from-orange to-orange-light rounded-xl transition-all duration-1000 ease-out" data-target-width="20%" style="width: 0%">
          </div>
        </div>
      </div>
    </div>

    <p class="animate-on-scroll text-center mt-10 text-gray-dark/60 text-sm max-w-lg mx-auto" data-animation="fade-in" data-delay="0.6s">
      必要なフォローアップまで付いて、この価格設定は「超破格」です。
    </p>
  </div>
</section>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const bars = entry.target.querySelectorAll('.comparison-bar');
          bars.forEach((bar, i) => {
            const target = bar.getAttribute('data-target-width');
            setTimeout(() => {
              bar.style.width = target;
              const label = bar.querySelector('[data-bar-label]');
              if (label) label.style.opacity = '1';
            }, i * 300);
          });
          observer.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.3 }
  );

  const container = document.getElementById('comparison-bars');
  if (container) observer.observe(container);
</script>

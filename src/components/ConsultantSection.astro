---
---

<section class="bg-white py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <p class="animate-on-scroll text-orange font-bold text-sm tracking-widest mb-4" data-animation="fade-in">CONSULTANT</p>
      <h2 class="animate-on-scroll text-2xl sm:text-3xl md:text-4xl font-black text-navy leading-tight" data-animation="fade-up">
        担当主席コンサルタント
      </h2>
    </div>

    <div class="max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-10 items-center">
        <!-- Photo -->
        <div class="animate-on-scroll" data-animation="slide-left">
          <div class="relative">
            <div class="rounded-2xl overflow-hidden shadow-xl">
              <img
                src="/images/consultant.jpg"
                alt="世古 誠 - 主席コンサルタント"
                class="w-full aspect-[3/4] object-cover object-top"
                loading="lazy"
              />
            </div>
            <div class="absolute -bottom-4 -right-4 bg-navy text-white rounded-xl px-5 py-3 shadow-lg">
              <p class="text-xs text-white/70">指導実績</p>
              <p class="font-accent font-extrabold text-2xl text-orange">850<span class="text-sm text-white font-sans font-bold">社以上</span></p>
            </div>
          </div>
        </div>

        <!-- Profile -->
        <div class="animate-on-scroll" data-animation="slide-right">
          <h3 class="text-3xl font-black text-navy mb-1">世古 誠</h3>
          <p class="text-sm text-navy mb-6">
            株式会社ミライの営業 代表取締役<br />
            日本で唯一の「営業ムダとり」コンサルタント / 「琉球経営™」提唱者
          </p>

          <div class="grid grid-cols-3 gap-4 mb-8">
            <div class="text-center bg-gray-light rounded-xl p-4">
              <p class="font-accent font-extrabold text-2xl sm:text-3xl text-navy">850</p>
              <p class="text-xs text-navy mt-1">社以上</p>
              <p class="text-xs font-bold text-navy">指導実績</p>
            </div>
            <div class="text-center bg-gray-light rounded-xl p-4">
              <p class="font-accent font-extrabold text-2xl sm:text-3xl text-navy">8,850</p>
              <p class="text-xs text-navy mt-1">名超</p>
              <p class="text-xs font-bold text-navy">研修受講者数</p>
            </div>
            <div class="text-center bg-gray-light rounded-xl p-4">
              <p class="font-accent font-extrabold text-2xl sm:text-3xl text-orange">4.93</p>
              <p class="text-xs text-navy mt-1">5点満点</p>
              <p class="text-xs font-bold text-navy">受講者満足度</p>
            </div>
          </div>

          <p class="text-sm text-navy leading-relaxed">
            ※「実践型研修講師」として、企業の「成長」にコミットします。
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

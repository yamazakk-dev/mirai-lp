---
---

<section class="relative min-h-[90vh] flex items-center bg-gradient-to-br from-navy-dark via-navy to-navy-light text-white pt-16">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,rgba(232,115,26,0.15),transparent_60%)]"></div>
  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20 md:py-28 text-center">
    <p class="animate-on-scroll inline-block bg-orange/20 border border-orange/40 text-orange font-bold text-base sm:text-lg tracking-widest mb-8 px-6 py-2 rounded-full" data-animation="fade-in">
      サブスク経営コンサルティング
    </p>
    <h1 class="animate-on-scroll text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-black leading-tight mb-6" data-animation="fade-up" data-delay="0.2s">
      月額<span class="font-accent text-orange text-4xl sm:text-5xl md:text-6xl lg:text-7xl">20,000</span>円で<br class="hidden sm:block" />
      御社の経営企画室が<br />
      手に入ります。
    </h1>
    <p class="animate-on-scroll text-base sm:text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-10 leading-relaxed" data-animation="fade-up" data-delay="0.4s">
      ディナー1回分の投資で、経験豊富なコンサルタントが<br class="hidden md:block" />
      あなたのビジネスに伴走します。
    </p>
    <div class="animate-on-scroll flex flex-col sm:flex-row gap-4 justify-center items-center" data-animation="fade-up" data-delay="0.6s">
      <a
        href="#contact"
        class="bg-orange hover:bg-orange-light text-white font-bold text-lg px-10 py-4 rounded-full transition-all duration-200 hover:scale-105 shadow-lg shadow-orange/30"
      >
        事前申込する
      </a>
      <a
        href="#service"
        class="border-2 border-white/40 hover:border-white text-white font-bold text-lg px-10 py-4 rounded-full transition-all duration-200 hover:bg-white/10"
      >
        サービス詳細を見る
      </a>
    </div>
    <div class="mt-16 animate-on-scroll" data-animation="fade-in" data-delay="0.8s">
      <p class="text-white/50 text-sm mb-3">対象：中小企業経営者、個人事業主向け</p>
      <div class="flex justify-center gap-8 text-white/60 text-sm">
        <span>※年間契約・次年度自動更新</span>
        <span>※税別</span>
      </div>
    </div>
  </div>
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-white/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

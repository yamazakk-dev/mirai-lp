---
---

<section class="bg-white py-20 md:py-28">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14">
      <p class="animate-on-scroll text-orange font-bold text-sm tracking-widest mb-4" data-animation="fade-in">MEDIA</p>
      <h2 class="animate-on-scroll text-2xl sm:text-3xl md:text-4xl font-black text-navy leading-tight" data-animation="fade-up">
        書籍・メディアによる情報発信
      </h2>
    </div>

    <div class="grid md:grid-cols-3 gap-8 max-w-4xl mx-auto">
      <!-- Book 1 -->
      <div class="animate-on-scroll text-center" data-animation="fade-up" data-delay="0.1s">
        <div class="bg-gray-light rounded-2xl p-8 mb-4 flex items-center justify-center min-h-[200px]">
          <div class="bg-white shadow-lg rounded-lg p-4 w-32 h-44 flex flex-col items-center justify-center transform -rotate-2">
            <p class="text-xs text-navy/60 mb-1">テレアポの常識を覆す</p>
            <p class="font-bold text-navy text-sm leading-tight text-center">「営業ムダとり」<br />戦略</p>
            <div class="w-8 h-0.5 bg-orange mt-2"></div>
          </div>
        </div>
        <h3 class="font-bold text-navy text-sm">著書</h3>
      </div>

      <!-- Book 2 -->
      <div class="animate-on-scroll text-center" data-animation="fade-up" data-delay="0.3s">
        <div class="bg-gray-light rounded-2xl p-8 mb-4 flex items-center justify-center min-h-[200px]">
          <div class="bg-white shadow-lg rounded-lg p-4 w-32 h-44 flex flex-col items-center justify-center transform rotate-2">
            <p class="text-xs text-navy/60 mb-1">日々の「気づき」で変わる</p>
            <p class="font-bold text-navy text-sm leading-tight text-center">ミライの営業<br />マニュアル</p>
            <div class="w-8 h-0.5 bg-orange mt-2"></div>
          </div>
        </div>
        <h3 class="font-bold text-navy text-sm">ブログ</h3>
      </div>

      <!-- YouTube -->
      <div class="animate-on-scroll text-center" data-animation="fade-up" data-delay="0.5s">
        <div class="bg-gray-light rounded-2xl p-8 mb-4 flex items-center justify-center min-h-[200px]">
          <div class="flex flex-col items-center">
            <svg class="w-16 h-16 text-red-500 mb-3" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
            <p class="font-bold text-navy text-sm">せこどんチャンネル</p>
            <p class="text-xs text-navy">営業セミナー・講演動画</p>
          </div>
        </div>
        <h3 class="font-bold text-navy text-sm">YouTube</h3>
      </div>
    </div>

    <p class="animate-on-scroll text-center text-sm text-navy mt-10 max-w-lg mx-auto" data-animation="fade-in" data-delay="0.6s">
      著書やYouTube、ブログ「営業戦略ブログ」を通じても、<br />
      常に最新のノウハウを提供し続けています。
    </p>
  </div>
</section>
